# MeetingScribe — Environment Variables Template
#
# Copy this file to `.env` (which is gitignored) and fill in the real values.
# These are consumed by Vite at build time. Client-side code can reference
# VITE_-prefixed vars via `import.meta.env.VITE_*`.
#
# Do NOT commit `.env` or any file containing real secrets.

# =============================================================================
# Google OAuth — developer identity: danspiegel@gmail.com
# GCP project ID: meetingscribe-492901
# Console: https://console.cloud.google.com/auth/clients?project=meetingscribe-492901
# =============================================================================

# Web application OAuth client (used with chrome.identity.launchWebAuthFlow + PKCE)
# Created in Phase 0 Step 1.4
VITE_GOOGLE_CLIENT_ID=1025955222510-2cd1c2s3f93r26uriv0gtsri0ib5gvjo.apps.googleusercontent.com

# Client secret — for installed/web app OAuth flow.
# PASTE your secret into `.env` (not here). Leave blank in .env.example.
# NOTE: For a Chrome extension using PKCE, the client secret is OPTIONAL —
# PKCE is designed for public clients that can't safely store secrets. We may
# end up not using this at all. Keeping the field here as a placeholder.
VITE_GOOGLE_CLIENT_SECRET=

# OAuth scopes Google requests. Space-separated.
VITE_GOOGLE_OAUTH_SCOPES="openid email profile https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/drive.file"

# =============================================================================
# Microsoft / Azure — developer identity: danspiegel@hotmail.com
# Azure App Registration tenant: common (accepts personal + work/school accounts)
# Console: https://portal.azure.com/
# =============================================================================

# Azure App Registration (client) ID — from Phase 0 Step 2.2
VITE_MICROSOFT_CLIENT_ID=3d88242c-3d5b-47d8-b3c6-21f937815e47

# Directory (tenant) ID of the developer's personal MSA tenant.
# Stored for reference only; at runtime we use "common" (see VITE_MICROSOFT_TENANT below)
# so the app accepts both personal MS accounts AND work/school accounts.
# VITE_MICROSOFT_DEV_TENANT_ID=2fa7943d-2a26-4271-b070-136002c7cd57

# Tenant — use "common" to accept both personal MS accounts and M365 work/school
VITE_MICROSOFT_TENANT=common

# OAuth scopes for Microsoft Graph. Space-separated.
# Calendars.Read — read calendar events (equivalent to calendar.readonly on Google)
# Files.ReadWrite — write files to OneDrive (drive.file equivalent)
# offline_access — required for refresh tokens
# User.Read — basic profile info
VITE_MICROSOFT_OAUTH_SCOPES="openid profile email offline_access User.Read Calendars.Read Files.ReadWrite"

# =============================================================================
# Dropbox — developer identity: danspiegel@gmail.com
# Console: https://www.dropbox.com/developers/apps
# =============================================================================

# Dropbox app key (client ID equivalent) — from Phase 0 Step 3.2
VITE_DROPBOX_APP_KEY=fes0gua5thykct3

# Dropbox app secret — PASTE into .env (leave blank here).
# For PKCE public clients this may be unused; keeping as placeholder.
VITE_DROPBOX_APP_SECRET=

# =============================================================================
# Extension runtime
# =============================================================================

# Chrome Extension ID (from first unpacked load; used to construct redirect URI)
# Redirect URI = https://${EXTENSION_ID}.chromiumapp.org/
VITE_EXTENSION_ID=fcjkeemghkfclpogdoblpoghakfagabk

# When true, the extension uses local dev endpoints and verbose logging.
VITE_DEV_MODE=true
